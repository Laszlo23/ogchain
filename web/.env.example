# Copy to `.env.local` for local dev. Never commit real secrets.
# Veriff — sessions are created server-side (POST /api/kyc/session). See https://devdocs.veriff.com/
# Copy the API key and Base URL from the same integration: Customer Portal → All Integrations → integration → API keys.
# HTTP 401 means the Base URL and API key are not a pair — set VERIFF_API_BASE to the exact Base URL from the portal.
VERIFF_API_BASE=
VERIFF_API_KEY=
NEXT_PUBLIC_VERIFF_API_KEY=
