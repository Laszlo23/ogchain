# Copy to `.env.local` for local dev. Never commit real secrets.
# Veriff — POST /api/kyc/session. See https://devdocs.veriff.com/
# Station API: set VERIFF_API_BASE=https://stationapi.veriff.com and VERIFF_SHARED_SECRET (master signature key) for HMAC.
# Callback: end-user return URL on YOUR site. Default = NEXT_PUBLIC_SITE_URL + /kyc, or set VERIFF_CALLBACK_URL.
VERIFF_API_BASE=https://stationapi.veriff.com
VERIFF_API_KEY=
# HMAC for Station (server-only; never NEXT_PUBLIC_)
VERIFF_SHARED_SECRET=
# Optional full URL; e.g. https://buildingculture.capital/kyc
VERIFF_CALLBACK_URL=
NEXT_PUBLIC_SITE_URL=https://buildingculture.capital
NEXT_PUBLIC_VERIFF_API_KEY=
