# Copy to `.env.local` in this directory. Next.js only loads env from `web/` for `npm run dev`.
#
# 0G (Galileo):  python3 ../scripts/sync_web_env.py ../deployments/testnet.json > .env.local
# Base mainnet: append  python3 ../scripts/sync_web_env.py ../deployments/base-mainnet.json >> .env.local
# Docker image:  repo-root `.env` for `docker compose build` (see ../.env.docker.example)

# --- 0G Galileo (chain id 16602) ---
NEXT_PUBLIC_OG_RPC=https://evmrpc-testnet.0g.ai
NEXT_PUBLIC_REGISTRY=0x0000000000000000000000000000000000000000
NEXT_PUBLIC_SHARE_FACTORY=0x0000000000000000000000000000000000000000
NEXT_PUBLIC_COMPLIANCE_REGISTRY=0x0000000000000000000000000000000000000000
NEXT_PUBLIC_WETH=0x0000000000000000000000000000000000000000
NEXT_PUBLIC_ROUTER=0x0000000000000000000000000000000000000000
NEXT_PUBLIC_LENDING_POOL=0x0000000000000000000000000000000000000000
NEXT_PUBLIC_PREDICTION_MARKET=0x0000000000000000000000000000000000000000
NEXT_PUBLIC_PROOF_NFT=0x0000000000000000000000000000000000000000
NEXT_PUBLIC_STAKING=0x0000000000000000000000000000000000000000
NEXT_PUBLIC_EXPLORER=https://chainscan-galileo.0g.ai
# NEXT_PUBLIC_GUESTBOOK=

# --- Base mainnet (chain id 8453) — sync from ../deployments/base-mainnet.json ---
NEXT_PUBLIC_BASE_RPC=https://mainnet.base.org
NEXT_PUBLIC_BASE_EXPLORER=https://basescan.org
NEXT_PUBLIC_BASE_REGISTRY=0x5aca19274B17B97e38da9eA851d91F0CC59DafBf
NEXT_PUBLIC_BASE_SHARE_FACTORY=0x4CA708ca735bBA49D7B2383071EA7FA1B7BDC614
NEXT_PUBLIC_BASE_COMPLIANCE_REGISTRY=0xa655c0B0037699433F0692356a3A142956103B7a
NEXT_PUBLIC_BASE_WETH=0x4412Afca8021F233aE6a41cEFD06b27759C0E9A9
NEXT_PUBLIC_BASE_ROUTER=0x753634Af9E86b26e5394f39496a1097C6f19B868
NEXT_PUBLIC_BASE_LENDING_POOL=0x0000000000000000000000000000000000000000
NEXT_PUBLIC_BASE_PREDICTION_MARKET=0x7D0E418d1a0e73a73C18F146a660346e2C113046
NEXT_PUBLIC_BASE_PROOF_NFT=0x9D81A95188939C1f708f9E43921C490f4Ef4e064
NEXT_PUBLIC_BASE_STAKING=0x3145f34A6CC6Ae34d9112f50885aEe826062ACbB
# Set after DeployPlatformSettlement + DeployPurchaseEscrowERC20 (see deployments/README.md)
NEXT_PUBLIC_BASE_PLATFORM_TOKEN=0x0000000000000000000000000000000000000000
NEXT_PUBLIC_BASE_PURCHASE_ESCROW_ERC20=0x0000000000000000000000000000000000000000
# NEXT_PUBLIC_BASE_GUESTBOOK=
# Base governance Safe (multisig) — public; not for connecting as an investor
NEXT_PUBLIC_BASE_GOVERNANCE_SAFE=0xCe03F6E734cC48393Ce41b257E998c68b521EB5c

# Optional: merge into primary sale map (see web/src/data/primary-sales.json, docs/primary-sale.md)
# NEXT_PUBLIC_PRIMARY_SALES_JSON={"sales":[]}

# Optional
# NEXT_PUBLIC_SITE_URL=http://localhost:3000
# NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=
# Social profiles (default @buildingcultu3 URLs — override per platform if needed)
# NEXT_PUBLIC_SOCIAL_X=https://x.com/buildingcultu3
# NEXT_PUBLIC_SOCIAL_INSTAGRAM=https://www.instagram.com/buildingcultu3/
# NEXT_PUBLIC_SOCIAL_LINKEDIN=https://www.linkedin.com/company/buildingcultu3

# Optional: concierge CTA mailto (see ContactConciergeCta)
# NEXT_PUBLIC_CONTACT_EMAIL=allocations@example.com
# Optional: whitelist requests from beta modal (falls back to NEXT_PUBLIC_CONTACT_EMAIL)
# NEXT_PUBLIC_WHITELIST_EMAIL=whitelist@example.com
# Optional: client event bus for analytics (see web/src/lib/analytics.ts) — align with /legal/privacy
# NEXT_PUBLIC_ANALYTICS_ENABLED=0
